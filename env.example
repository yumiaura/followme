# GitHub token with permissions for follow and starring repositories.
GITHUB_TOKEN=ghp_your_personal_access_token_here

# codecat runtime settings
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Grade threshold for follow/star actions.
FOLLOW_Y=7.5

# Search setup for batch mode.
FOLLOW_SCAN_LIMIT=100
FOLLOW_LANGUAGE=Python
FOLLOW_OUTPUT_LANGUAGE=English
MAX_STARS=100

# Output files.
FOLLOW_RESULTS_CSV=data/results.csv

# Runtime tuning.
FOLLOW_HTTP_TIMEOUT=30
FOLLOW_DRY_RUN=false
FOLLOW_INFINITE_SLEEP_SECONDS=600

# Optional local override when codecat is not installed via pip.
# CODECAT_DIR=/absolute/path/to/codecat
