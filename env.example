# GitHub token with permissions for follow and starring repositories.
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Ollama runtime settings.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Grade thresholds for GitHub actions.
FOLLOW_GRADE=7.5
FOLLOW_STAR_GRADE=7.5

# Search setup for batch mode.
FOLLOW_SCAN_LIMIT=100
FOLLOW_LANGUAGE=Python
FOLLOW_OUTPUT_LANGUAGE=English
MAX_STARS=100

# Output files.
FOLLOW_RESULTS_CSV=data/results.csv
FOLLOW_ANALYSIS_DIR=data/analysis

# Runtime tuning.
FOLLOW_HTTP_TIMEOUT=30
FOLLOW_DRY_RUN=false
FOLLOW_INFINITE_SLEEP_SECONDS=600
FOLLOW_MAX_FILES=25
FOLLOW_MAX_LINES_PER_FILE=120
FOLLOW_MAX_CHARS_PER_FILE=6000
FOLLOW_MAX_TOTAL_CHARS=70000
FOLLOW_MAX_FILE_BYTES=524288
FOLLOW_GIT_CLONE_DEPTH=1
FOLLOW_INCLUDE_HIDDEN_FILES=false
FOLLOW_SAVE_DIGEST=false
FOLLOW_EXTENSIONS=.py,.pyi,.js,.ts,.tsx,.jsx,.go,.rs,.java,.kt,.c,.h,.cpp,.hpp,.cs,.php,.rb,.swift,.scala,.lua,.sh,.bash,.zsh,.sql,.yaml,.yml,.toml,.json,.ini,.cfg,.md,.txt

# Optional Telegram notifications (send when grade > TELEGRAM_GRADE).
TELEGRAM_BOT_TOKEN=
TELEGRAM_HOME_CHANNEL=
TELEGRAM_CHAT_SECURITY=
TELEGRAM_GRADE=9.49
TELEGRAM_LANGUAGE=English
